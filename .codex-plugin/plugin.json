{
  "name": "remem-mcp",
  "version": "0.2.0",
  "description": "Reasoning memory layer for AI agents providing long-term semantic storage, contradiction detection, and fact consolidation.",
  "engines": {
    "codex": ">=0.1.0"
  },
  "mcpServers": {
    "remem": {
      "type": "stdio",
      "command": "cargo",
      "args": ["run", "-q", "-p", "rememhq-mcp"],
      "env": {
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY}"
      }
    }
  }
}
